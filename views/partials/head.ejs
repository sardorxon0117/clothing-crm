<!DOCTYPE html>
<html lang="uz">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle : 'CRM' %> — Stil Savdo</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" type="image/png" href="https://t4.ftcdn.net/jpg/03/14/69/05/360_F_314690578_GWP3Ru8FITNHhOejaAm6PUDRu3txSiQY.jpg">
</head>
<body>
<div class="ambient"><span class="blob blob-1"></span><span class="blob blob-2"></span><span class="blob blob-3"></span></div>
<div class="app">

  <!-- Yon menyu -->
  <aside class="sidebar">
    <div class="brand">
      <div class="brand-mark">S</div>
      <div class="brand-text">
        <span class="brand-name">Stil Savdo</span>
        <span class="brand-sub">CRM tizimi</span>
      </div>
    </div>

    <nav class="nav">
      <a href="/" class="nav-link <%= active === 'dashboard' ? 'active' : '' %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
        Boshqaruv paneli
      </a>
      <a href="/customers" class="nav-link <%= active === 'customers' ? 'active' : '' %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        Mijozlar
      </a>
      <a href="/products" class="nav-link <%= active === 'products' ? 'active' : '' %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
        Mahsulotlar
      </a>
      <a href="/orders" class="nav-link <%= active === 'orders' ? 'active' : '' %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
        Buyurtmalar
      </a>
      <a href="/reports" class="nav-link <%= active === 'reports' ? 'active' : '' %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
        Hisobotlar
      </a>
      <a href="/settings" class="nav-link <%= active === 'settings' ? 'active' : '' %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
        Sozlamalar
      </a>
    </nav>

    <div class="sidebar-foot">
      <div class="user-chip">
        <div class="user-avatar"><%= (adminName || 'A').charAt(0).toUpperCase() %></div>
        <div class="user-meta">
          <span class="user-name"><%= adminName || 'Administrator' %></span>
          <span class="user-role">Administrator</span>
        </div>
      </div>
      <form action="/logout?_method=POST" method="POST" class="logout-form">
        <button type="submit" class="logout-btn">Chiqish</button>
      </form>
    </div>
  </aside>

  <!-- Asosiy maydon -->
  <main class="main">
    <header class="topbar">
      <button class="menu-toggle" onclick="document.body.classList.toggle('sidebar-open')">☰</button>
      <h1 class="page-title"><%= typeof pageTitle !== 'undefined' ? pageTitle : '' %></h1>
      <div class="topbar-right">
        <span class="topbar-date"><%= new Date().toLocaleDateString('uz-UZ', { year:'numeric', month:'long', day:'numeric' }) %></span>
      </div>
    </header>

    <div class="content">
